{
  "info": {
    "name": "Trading Engine API",
    "_postman_id": "c1f7c1b2-1234-4567-890a-abcdef123456",
    "description": "API collection for trading backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/users/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"Martin\",\n  \"balance\": 100000\n}"
            }
          }
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/1"
          }
        },
        {
          "name": "Update Balance",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/users/1/balance/update",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"delta_balance\": -500\n}"
            }
          }
        },
        {
          "name": "Set Balance",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/users/1/balance/set",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"balance\": 200000\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/orders/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1,\n  \"asset_id\": 1,\n  \"side\": \"bid\",\n  \"price\": 100,\n  \"quantity\": 10\n}"
            }
          }
        },
        {
          "name": "Get Order",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/orders/1"
          }
        },
        {
          "name": "Get Orders By Side (bid)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/orders/side/bid"
          }
        },
        {
          "name": "Get Orders By Side (ask)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/orders/side/ask"
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/orders/1/cancel"
          }
        }
      ]
    },
    {
      "name": "Prices",
      "item": [
        {
          "name": "Get Last N Prices",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/prices/last/1?n=50"
          }
        },
        {
          "name": "Get All Prices",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/prices/all/1"
          }
        }
      ]
    },
    {
      "name": "Positions",
      "item": [
        {
          "name": "Get Position",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/positions?user_id=1&asset_id=1"
          }
        },
        {
          "name": "Get All User Positions",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/positions/user/1"
          }
        }
      ]
    }
  ]
}