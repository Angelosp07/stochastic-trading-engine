          }
        },
        {
          "name": "Get Price History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/history?n=50",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["history"],
              "query": [
                { "key": "n", "value": "50" }
              ]
